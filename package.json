{
  "name": "libe-move",
  "version": "0.1.1",
  "type": "module",
  "scripts": {
    "db:migrate": "node --env-file=.env scripts/migrate.js",
    "db:init": "node --env-file=.env scripts/init.js",
    "db:seed": "node --env-file=.env scripts/seed.js",
    "dev": "node --watch-path=src --env-file=.env src/server.js",
    "build": "npm run build:client && npm run build:server",
    "build:client": "vite build --outDir dist/client",
    "build:server": "vite build --ssr src/entry-server.js --outDir dist/server",
    "serve": "NODE_ENV=production node src/server.js"
  },
  "dependencies": {
    "@google/generative-ai": "^0.24.1",
    "argon2": "^0.44.0",
    "cors": "^2.8.6",
    "cron-parser": "^5.5.0",
    "dotenv": "^17.4.0",
    "express": "^4.21.1",
    "express-rate-limit": "^8.3.2",
    "helmet": "^8.1.0",
    "jsonwebtoken": "^9.0.3",
    "node-cron": "^4.2.1",
    "pg": "^8.13.1",
    "pino": "^10.3.1",
    "pino-pretty": "^13.1.3",
    "socket.io": "^4.8.3",
    "socket.io-client": "^4.8.3",
    "vue": "^3.5.12",
    "vue-router": "^4.4.5"
  },
  "devDependencies": {
    "@vitejs/plugin-vue": "^5.1.4",
    "autoprefixer": "^10.4.27",
    "postcss": "^8.5.8",
    "tailwindcss": "^3.4.19",
    "vite": "^5.4.10"
  }
}
